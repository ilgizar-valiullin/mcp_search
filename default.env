# === MCP Web Hound — Default Configuration ===
# Lines starting with # are section headers or keys requiring manual setup.
# Uncommented keys are active defaults — edit values to override.

# --- Server ---
LOG_LEVEL=info
DB_FILENAME=search.db

# --- Search Providers (free, no key) ---
DDG_ENABLED=true
BING_ENABLED=true
STARTPAGE_ENABLED=true
BRAVE_WEB_ENABLED=true

# --- API Keys (uncomment and add your key to enable) ---
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=

# --- Platform Tokens (uncomment and add your token to enable) ---
# GITHUB_TOKEN=
# GITLAB_TOKEN=

# --- Search Engine ---
PROVIDER_ORDER=startpage,ddg,brave_web,bing,brave_api,tavily,exa,firecrawl
PROVIDER_EXECUTION_MODE=parallel
MAX_PARALLEL_PROVIDERS=2
MAX_RESULTS_AFTER_RERANK=10
SEARCH_TIMEOUT_MS=15000

# --- Budget ---
BUDGET_MAX_SEARCHES=15
BUDGET_MAX_FETCHES=30
BUDGET_WINDOW_MINUTES=30

# --- Cache ---
CACHE_MAX_SIZE_MB=500
CACHE_EVICTION_INTERVAL_MIN=30
CACHE_TTL_MINUTES=1440

# --- AI Features ---
SEMANTIC_ENABLED=true
EMBEDDING_MODEL=multilingual-e5-small
EMBEDDING_DIMENSION=384
SEMANTIC_THRESHOLD=0.92
INTENT_CLASSIFIER_MODEL=Xenova/nli-deberta-v3-xsmall
RERANK_ENABLED=true

# --- Search Logging ---
# SEARCH_LOG_ENABLED=true  # Enable training data logging (see docs/diagrams/search-logging-flow.md)

# --- Deduplication ---
SESSION_DEDUP_WINDOW_MINUTES=5
SESSION_DEDUP_STRETCH_MINUTES=0

# --- DuckDuckGo Tuning ---
DDG_DELAY_MS=1000
DDG_MAX_PER_MINUTE=10
DDG_RESULTS_PER_PAGE=10
DDG_MAX_PAGES=1

# --- Bing Tuning ---
BING_RESULTS_PER_PAGE=10
BING_MAX_PAGES=1

# --- Rate Limits (RPM / RPD / RPMONTH) ---
DDG_RPM=10
DDG_RPD=200
DDG_RPMONTH=6000
BING_RPM=15
BING_RPD=60
BING_RPMONTH=1800
STARTPAGE_RPM=10
STARTPAGE_RPD=200
STARTPAGE_RPMONTH=6000
BRAVE_RPM=15
BRAVE_RPD=60
BRAVE_RPMONTH=2000
BRAVE_WEB_RPM=10
BRAVE_WEB_RPD=100
BRAVE_WEB_RPMONTH=6000
TAVILY_RPM=10
TAVILY_RPD=30
TAVILY_RPMONTH=1000
EXA_RPM=10
EXA_RPD=30
EXA_RPMONTH=1000
FIRECRAWL_RPM=5
FIRECRAWL_RPD=15
FIRECRAWL_RPMONTH=500
