{
  "name": "search-mcp",
  "version": "1.5.0",
  "description": "MCP Search Server — unified search, GitHub search, and GitLab search tools with caching, reranking, and rate limits",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:providers": "vitest run tests/integration/",
    "test:all": "vitest run tests/ tests/integration/",
    "lint": "eslint src/",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "search",
    "ai",
    "agent",
    "duckduckgo"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "@mozilla/readability": "latest",
    "better-sqlite3": "latest",
    "dotenv": "latest",
    "linkedom": "latest",
    "pino": "latest",
    "turndown": "latest",
    "turndown-plugin-gfm": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "^20.0.0",
    "@types/turndown": "latest",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "latest",
    "rimraf": "latest",
    "tsx": "latest",
    "typescript": "^5.3.0",
    "vitest": "latest"
  },
  "optionalDependencies": {
    "@xenova/transformers": "latest",
    "sqlite-vec": "latest"
  }
}
